# Shared
NODE_ENV=development

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_KEY=           # publishable key (sb_publishable_xxx) or legacy anon key

# Backend
BACKEND_PORT=4000
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
DATABASE_URL=postgres://communitymap:communitymap@localhost:5433/communitymap
SUPABASE_SECRET_KEY=                # secret key (sb_secret_xxx) or legacy service_role key

# PostgreSQL
POSTGRES_USER=communitymap
POSTGRES_PASSWORD=communitymap
POSTGRES_DB=communitymap

# AWS
AWS_REGION=ap-southeast-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
